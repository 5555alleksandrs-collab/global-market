TELEGRAM_BOT_TOKEN=

# Опционально: ссылка на README или GitHub — показывается в /help и при «привет»
# HELP_URL=https://github.com/you/repo

# ID таблицы из URL (можно вставить целиком ссылку — ID извлечётся)
SPREADSHEET_ID=https://docs.google.com/spreadsheets/d/10liVkIAhBZaQ4P2-yOPDQCCaGm8G1md2lLb_KqfAt2o/edit?gid=2070458361#gid=2070458361

# Имя вкладки внизу Google Таблицы (Лист1, Sheet1, …) — как в интерфейсе, не «название бота»
WORKSHEET_NAME=пробив

# Если листа с таким именем нет: запасные имена через запятую; иначе берётся первый лист (см. ниже)
# WORKSHEET_FALLBACK_NAMES=Sheet1,Лист 1

# 1 = если ни одно имя не подошло, писать в первый лист таблицы; 0 = только ошибка
# WORKSHEET_FALLBACK_TO_FIRST=1

# eSIM: US, Япония 🇯🇵 (REGION_SUFFIX_JP); SIM: UK 🇬🇧, KR, HK, AU, … (REGION_SUFFIX_GB).
# REGION_SUFFIX_JP=eSIM
# REGION_SUFFIX_GB=SIM

GOOGLE_CREDENTIALS_PATH=credentials.json

# С какой строки идут названия товаров в A (часто 2, если строка 1 — шапка)
DATA_START_ROW=2

# Колонки: F = первая цена, G = вторая (как на вашем скрине)
FIRST_PRICE_COLUMN=6
SECOND_PRICE_COLUMN=7

MAX_SCAN_ROWS=5000

# Цвета поставщиков RGB 0–1 (подстройте под вашу легенду справа)
SUPPLIER_COLORS_PATH=supplier_colors.json

# Кнопки поставщиков в боте (имена как в таблице, через запятую). Пусто = все ключи из supplier_colors.json
# SUPPLIER_BUTTONS=AL,BB,Otm,Cell tech,Tell,Silver,CC,Metrion

# ALLOWED_USER_IDS=
# PRICE_MIN=100
# PRICE_MAX=9999999

# Файл накопления цен по поставщикам (min / 2-я между сообщениями)
# OFFERS_STORE_PATH=data/offers.json

# Каталог строк как в колонке A (fallback к нечёткому поиску). Несколько файлов через запятую.
# PRICE_SHEET_CATALOG_PATH=data/price_sheet_catalog.txt
