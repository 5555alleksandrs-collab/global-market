# Скопируйте в .env и заполните.
# Токен: @BotFather в Telegram
BOT_TOKEN=

# Через запятую: ваши numeric Telegram user id (узнать у @userinfobot)
ADMIN_TELEGRAM_IDS=123456789

# Сколько пиров создаёт образ при первом старте (должно совпадать с PEERS в docker-compose)
PEERS=10

# Публичный адрес сервера WireGuard (если не используете SERVERURL=auto в compose)
# SERVERURL=203.0.113.50
